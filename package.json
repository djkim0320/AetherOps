{
  "name": "aetherops",
  "version": "0.2.0",
  "private": true,
  "description": "AetherOps autonomous research agent web app.",
  "type": "module",
  "main": "dist-server/server/webServer.js",
  "engines": {
    "node": ">=22.16.0 <23"
  },
  "scripts": {
    "dev": "node scripts/dev-web.mjs",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','dist-server']) fs.rmSync(p,{recursive:true,force:true});\"",
    "lint": "eslint . --max-warnings=0",
    "architecture:check": "depcruise --config .dependency-cruiser.cjs --output-type err-long src",
    "size:check": "node scripts/check-module-size.mjs",
    "stylelint": "stylelint \"src/renderer/**/*.css\"",
    "css:tokens": "node scripts/check-css-tokens.mjs",
    "format": "prettier --write --ignore-unknown package.json README.md eslint.config.js vite.config.ts vitest.config.ts tsconfig*.json .dependency-cruiser.cjs .stylelintrc.cjs .prettierrc.json .github src scripts tests",
    "format:check": "prettier --check --ignore-unknown package.json README.md eslint.config.js vite.config.ts vitest.config.ts tsconfig*.json .dependency-cruiser.cjs .stylelintrc.cjs .prettierrc.json .github src scripts tests",
    "migrate:check": "node scripts/migrate.mjs check",
    "migrate:apply": "node scripts/migrate.mjs apply",
    "migrate:verify": "node scripts/migrate.mjs verify",
    "migrate:rollback": "node scripts/migrate.mjs rollback",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node dist-server/server/webServer.js",
    "build": "npm run clean && tsc -p tsconfig.app.json && vite build && npm run server:build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node-unit",
    "test:renderer": "vitest run --project renderer-component",
    "test:storage": "vitest run --project storage-integration",
    "test:contracts": "vitest run --project api-contract",
    "doctor": "node scripts/doctor.mjs",
    "engineering:install-tools": "node scripts/engineering/install-embedded-toolchain.mjs",
    "ui:verify": "node scripts/ui-verify.mjs",
    "metadata:verify": "npm run server:build && node scripts/research-metadata-verify.mjs",
    "autonomy:verify": "node scripts/autonomy-verify.mjs",
    "selftest": "node scripts/selftest.mjs",
    "selftest:blocked": "node scripts/selftest.mjs --mode=blocked --skip-static",
    "selftest:live": "node scripts/selftest.mjs --mode=live"
  },
  "dependencies": {
    "@openai/codex": "0.144.1",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-scroll-area": "1.2.14",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@tanstack/react-query": "5.101.2",
    "lucide-react": "1.14.0",
    "playwright": "^1.60.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "webxfoil-wasm": "0.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "4.12.1",
    "dependency-cruiser": "18.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.6"
  },
  "overrides": {
    "undici": "7.28.0"
  }
}

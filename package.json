{
  "name": "aetherops",
  "version": "0.1.0",
  "private": true,
  "description": "AetherOps autonomous research agent web app.",
  "type": "module",
  "main": "dist-server/server/webServer.js",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "node scripts/dev-web.mjs",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','dist-server','dist-electron']) fs.rmSync(p,{recursive:true,force:true});\"",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node dist-server/server/webServer.js",
    "web:dev": "node scripts/dev-web.mjs",
    "web:build": "npm run clean && tsc -p tsconfig.app.json && vite build && npm run server:build",
    "build": "npm run web:build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "doctor": "node scripts/doctor.mjs",
    "ui:verify": "node scripts/ui-layout-verify.mjs",
    "metadata:verify": "npm run server:build && node scripts/research-metadata-verify.mjs",
    "selftest": "node scripts/selftest.mjs",
    "selftest:blocked": "node scripts/selftest.mjs --mode=blocked",
    "selftest:live": "node scripts/selftest.mjs --mode=live"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "opencode-ai": "^1.15.5",
    "playwright": "^1.60.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
